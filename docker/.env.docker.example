# Docker Compose Environment Variables
# Copy this file to .env in the project root (same directory as docker-compose.yml)
# and fill in your actual values

# Optional: Application configuration
SIDEREAL_PORT=5000
ENABLE_PLATE_SOLVING=true
PLATE_SOLVE_MAX_CONCURRENT=3

# Optional: Immich Integration
IMMICH_URL=http://your-immich-server:2283
IMMICH_API_KEY=your_immich_api_key_here

# Optional: Astrometry.net Integration
ASTROMETRY_API_KEY=your_astrometry_api_key_here

# Optional: PostgreSQL (only needed with docker-compose.postgres.yml)
# By default Sidereal uses a built-in SQLite database — no database setup required.
# To use PostgreSQL, layer the postgres override and set a password:
#   docker compose -f docker-compose.prod.yml -f docker-compose.postgres.yml up -d
# POSTGRES_PASSWORD=your_secure_database_password_here

# SECURITY NOTES:
# 1. This file should be created as .env in the project root
# 2. Never commit the actual .env file to version control
# 3. Use strong, unique passwords
# 4. These can also be configured via the admin web interface after startup
