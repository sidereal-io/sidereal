{
  "name": "sidereal",
  "version": "0.10.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev:server": "NODE_ENV=development tsx --env-file=.env apps/server/src/index.ts",
    "dev:server:watch": "NODE_ENV=development nodemon --watch apps/server --ext ts,js --exec \"tsx --env-file=.env apps/server/src/index.ts\"",
    "dev:worker": "NODE_ENV=development tsx --env-file=.env apps/server/src/workers/worker.ts",
    "dev:worker:standalone": "NODE_ENV=development tsx --env-file=.env.worker apps/server/src/workers/worker.ts",
    "dev:frontend": "vite",
    "dev": "concurrently \"npm run dev:server:watch\" \"npm run dev:frontend\" \"npm run dev:worker\"",
    "build": "vite build && tsx tools/scripts/build.ts",
    "build:docker": "vite build && npm run copy-assets && tsx tools/scripts/build.ts",
    "copy-assets": "cp -r tools dist/ && cp drizzle.config.ts dist/",
    "start": "NODE_ENV=production node dist/index.js",
    "start:worker": "NODE_ENV=production node dist/worker.js",
    "start:worker:standalone": "NODE_ENV=production node dist/worker.js",
    "docker:build": "docker build --no-cache -t sidereal .",
    "docker:run": "docker compose up -d --build --force-recreate",
    "docker:stop": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "check": "tsc",
    "test": "tsx --test packages/shared/src/**/*.test.ts",
    "test:scripts": "tsx --test \"tools/scripts/sync-beads-github/**/*.test.ts\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "db:migrate": "node tools/scripts/migrate-db.js",
    "seed": "tsx tools/scripts/seed.ts",
    "seed:reset": "tsx tools/scripts/seed.ts --reset",
    "push:github": "tsx tools/scripts/push-github.ts",
    "pull:github": "tsx tools/scripts/pull-github.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@hookform/resolvers": "^5.2.2",
    "@jridgewell/trace-mapping": "^0.3.31",
    "@neondatabase/serverless": "^1.1.0",
    "@octokit/rest": "^22.0.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
